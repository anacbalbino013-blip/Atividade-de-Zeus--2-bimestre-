function analisar() {
    if (pessoas.length === 0) {
        alert("Nenhuma pessoa cadastrada!");
        return;
    }

    let resultado = "";
    let somaIdades = 0;

    for (let i = 0; i < pessoas.length; i++) {
        let nome = pessoas[i].nome;
        let idade = pessoas[i].idade;

        somaIdades += idade;

        if (idade < 16) {
            resultado += nome + " - não pode votar!<br>";
        } else if (idade < 18 || idade >= 60) {
            resultado += nome + " - voto facultativo<br>";
        } else {
            resultado += nome + " - voto obrigatório<br>";
        }
    }

    let media = somaIdades / pessoas.length;

    resultado += `<br><strong>Média das idades: ${media.toFixed(1)} anos</strong>`;

    document.getElementById("resultado").innerHTML = resultado;

    }
